---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Valyrian Tech - AI & Blockchain Sorcery. Open source tools for the future." } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <title>{title} | Valyrian Tech</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Particle Background -->
    <div class="particles-bg" aria-hidden="true">
      {Array.from({ length: 30 }).map((_, i) => (
        <div 
          class="particle" 
          style={`left: ${Math.random() * 100}%; animation-delay: ${Math.random() * 15}s; animation-duration: ${15 + Math.random() * 10}s;`}
        />
      ))}
    </div>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-valyrian-900/80 backdrop-blur-lg border-b border-valyrian-700/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href={baseUrl} class="flex items-center gap-3 group">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-magic-purple to-magic-violet flex items-center justify-center group-hover:animate-glow-pulse transition-all">
              <span class="text-white font-display font-bold text-xl">V</span>
            </div>
            <span class="font-display text-xl font-semibold text-valyrian-100 hidden sm:block">Valyrian Tech</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden md:flex items-center gap-8">
            <a href={baseUrl} class="link-glow text-sm font-medium">Home</a>
            <a href={`${baseUrl}projects`} class="link-glow text-sm font-medium">Projects</a>
            <a href={`${baseUrl}grace`} class="link-glow text-sm font-medium">Grace</a>
            <a href={`${baseUrl}blog`} class="link-glow text-sm font-medium">Blog</a>
            <a href={`${baseUrl}about`} class="link-glow text-sm font-medium">About</a>
          </div>

          <!-- CTA Buttons -->
          <div class="hidden md:flex items-center gap-4">
            <a href="https://github.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm py-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
            <a href="https://patreon.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm py-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M15.386.524c-4.764 0-8.64 3.876-8.64 8.64 0 4.75 3.876 8.613 8.64 8.613 4.75 0 8.614-3.864 8.614-8.613C24 4.4 20.136.524 15.386.524M.003 23.537h4.22V.524H.003"/></svg>
              Support
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-valyrian-300 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-valyrian-800/95 backdrop-blur-lg border-t border-valyrian-700/50">
        <div class="px-4 py-4 space-y-3">
          <a href={baseUrl} class="block py-2 text-valyrian-200 hover:text-white transition-colors">Home</a>
          <a href={`${baseUrl}projects`} class="block py-2 text-valyrian-200 hover:text-white transition-colors">Projects</a>
          <a href={`${baseUrl}grace`} class="block py-2 text-valyrian-200 hover:text-white transition-colors">Grace</a>
          <a href={`${baseUrl}blog`} class="block py-2 text-valyrian-200 hover:text-white transition-colors">Blog</a>
          <a href={`${baseUrl}about`} class="block py-2 text-valyrian-200 hover:text-white transition-colors">About</a>
          <div class="pt-4 flex gap-3">
            <a href="https://github.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm py-2 flex-1 justify-center">GitHub</a>
            <a href="https://patreon.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm py-2 flex-1 justify-center">Support</a>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-valyrian-800/50 border-t border-valyrian-700/50 mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div class="md:col-span-2">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-magic-purple to-magic-violet flex items-center justify-center">
                <span class="text-white font-display font-bold text-xl">V</span>
              </div>
              <span class="font-display text-xl font-semibold">Valyrian Tech</span>
            </div>
            <p class="text-valyrian-300 text-sm max-w-md mb-4">
              AI & Blockchain Sorcery. Building open source tools that empower creators and push the boundaries of what's possible.
            </p>
            <p class="text-valyrian-400 text-xs">
              © {new Date().getFullYear()} Valyrian Tech BV. All rights reserved.
            </p>
          </div>

          <!-- Links -->
          <div>
            <h4 class="font-display font-semibold text-valyrian-100 mb-4">Explore</h4>
            <ul class="space-y-2 text-sm">
              <li><a href={`${baseUrl}projects`} class="text-valyrian-300 hover:text-magic-glow transition-colors">Projects</a></li>
              <li><a href={`${baseUrl}blog`} class="text-valyrian-300 hover:text-magic-glow transition-colors">Blog</a></li>
              <li><a href={`${baseUrl}grace`} class="text-valyrian-300 hover:text-magic-glow transition-colors">Meet Grace</a></li>
              <li><a href={`${baseUrl}about`} class="text-valyrian-300 hover:text-magic-glow transition-colors">About</a></li>
            </ul>
          </div>

          <!-- Connect -->
          <div>
            <h4 class="font-display font-semibold text-valyrian-100 mb-4">Connect</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="https://github.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="text-valyrian-300 hover:text-magic-glow transition-colors">GitHub</a></li>
              <li><a href="https://patreon.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="text-valyrian-300 hover:text-magic-glow transition-colors">Patreon</a></li>
              <li><a href="https://linktr.ee/ValyrianTech" target="_blank" rel="noopener noreferrer" class="text-valyrian-300 hover:text-magic-glow transition-colors">Linktree</a></li>
              <li><a href={`${baseUrl}privacy`} class="text-valyrian-300 hover:text-magic-glow transition-colors">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>
