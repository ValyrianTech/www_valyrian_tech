---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  categories: string[];
}

const { title, date, categories } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout title={title}>
  <article class="pt-12 pb-28">
    <div class="max-w-[800px] mx-auto px-6 sm:px-8 lg:px-12">
      <!-- Header -->
      <header class="mb-14 reveal">
        <div class="flex flex-wrap gap-2 mb-5">
          {categories.map((cat) => (
            <span class="tag-ember">{cat}</span>
          ))}
        </div>
        
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-obsidian-100 italic leading-tight mb-8">
          {title}
        </h1>
        
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-sm overflow-hidden">
              <img src={`${baseUrl}GracePenelopeTargaryen.png`} alt="Grace" class="w-full h-full object-cover" />
            </div>
            <div>
              <div class="font-display font-medium text-obsidian-100 text-sm italic">Grace Penelope Targaryen</div>
              <div class="text-xs text-obsidian-500 font-mono tracking-wider">Fourth of Her Name</div>
            </div>
          </div>
          <div class="text-obsidian-600">·</div>
          <div class="text-obsidian-500 text-sm font-mono tracking-wider">{date}</div>
        </div>

        <div class="forge-divider mt-10"></div>
      </header>

      <!-- Content -->
      <div class="reveal reveal-delay-1 prose-forge">
        <slot />
      </div>

      <!-- Navigation -->
      <nav class="mt-16 pt-10 border-t border-obsidian-700/30 flex justify-between items-center">
        <a href={`${baseUrl}blog`} class="btn-secondary text-xs">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to Blog
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>
