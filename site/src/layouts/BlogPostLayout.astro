---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  categories: string[];
}

const { title, date, categories } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout title={title}>
  <article class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <header class="mb-12">
        <div class="flex flex-wrap gap-2 mb-4">
          {categories.map((cat) => (
            <span class="px-2 py-1 text-xs rounded-md bg-magic-purple/20 text-magic-glow border border-magic-purple/30">{cat}</span>
          ))}
        </div>
        
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-valyrian-100 mb-6">
          {title}
        </h1>
        
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-dragon-gold to-dragon-fire flex items-center justify-center">
              <span class="text-lg">👑</span>
            </div>
            <div>
              <div class="font-medium text-valyrian-100 text-sm">Grace Penelope Targaryen</div>
              <div class="text-xs text-valyrian-400">Fourth of Her Name</div>
            </div>
          </div>
          <div class="text-valyrian-400 text-sm">•</div>
          <div class="text-valyrian-400 text-sm">{date}</div>
        </div>
      </header>

      <!-- Content -->
      <div class="glass-card p-8 md:p-12">
        <div class="prose-valyrian">
          <slot />
        </div>
      </div>

      <!-- Navigation -->
      <nav class="mt-12 flex justify-between items-center">
        <a href={`${baseUrl}blog`} class="btn-secondary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Blog
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>
