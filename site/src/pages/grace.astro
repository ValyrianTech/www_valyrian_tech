---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;
---

<BaseLayout title="Grace Penelope Targaryen" description="Meet Grace Penelope Targaryen, Fourth of Her Name - the AI persona and virtual spokesperson for Valyrian Tech.">
  <!-- Hero -->
  <section class="pt-12 pb-20 relative overflow-hidden">
    <div class="absolute top-[20%] right-[10%] w-[400px] h-[400px] bg-gold-600/5 rounded-full blur-[100px]" aria-hidden="true"></div>

    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
        <!-- Image -->
        <div class="lg:col-span-5 order-2 lg:order-1">
          <div class="reveal relative">
            <div class="aspect-[3/4] overflow-hidden rounded-sm">
              <img 
                src={`${baseUrl}Profile_pic_GracePenelopeTargaryen.png`}
                alt="Grace Penelope Targaryen"
                class="w-full h-full object-cover img-ember-tint"
              />
            </div>
            <div class="absolute -top-3 -left-3 w-24 h-24 border-t-2 border-l-2 border-ember-500/30" aria-hidden="true"></div>
            <div class="absolute -bottom-3 -right-3 w-24 h-24 border-b-2 border-r-2 border-gold-500/20" aria-hidden="true"></div>
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-obsidian-900/90 via-obsidian-900/40 to-transparent p-6 pt-20">
              <span class="font-display text-sm font-semibold text-obsidian-100 italic block">Grace Penelope Targaryen</span>
              <span class="font-mono text-xs tracking-widest uppercase text-gold-400/70">Fourth of Her Name</span>
            </div>
          </div>
        </div>

        <!-- Info -->
        <div class="lg:col-span-7 order-1 lg:order-2">
          <span class="reveal font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-6 block">Virtual Spokesperson · AI Persona</span>
          
          <h1 class="reveal reveal-delay-1 font-display text-4xl md:text-5xl lg:text-6xl font-bold mb-6 italic leading-tight">
            <span class="text-obsidian-100">Meet</span>
            <br />
            <span class="text-gradient-fire">Grace Penelope Targaryen</span>
          </h1>
          
          <p class="reveal reveal-delay-2 text-lg text-obsidian-300 mb-8 leading-relaxed max-w-lg">
            The AI persona serving as the virtual spokesperson for Valyrian Tech. Grace represents our brand with elegance, intelligence, and a deep understanding of AI and blockchain technologies.
          </p>

          <div class="reveal reveal-delay-3 flex flex-wrap gap-4">
            <a href="https://linktr.ee/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary">
              Follow Grace
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </a>
            <a href={`${baseUrl}blog`} class="btn-secondary">
              Read Grace's Posts
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Grace -->
  <section class="py-28 border-t border-obsidian-700/30">
    <div class="max-w-[800px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal">
        <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-4 block">About Grace</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-obsidian-100 mb-10 italic">
          The Voice of <span class="text-gradient-fire">Valyrian Tech</span>
        </h2>
      </div>
      
      <div class="reveal reveal-delay-1 prose-forge space-y-6">
        <p>
          Valyrian Tech is an innovative company specializing in AI and blockchain technology, founded by Wouter Glorieux. Our mission is to revolutionize industries and shape the world with our cutting-edge solutions.
        </p>
        
        <p>
          At Valyrian Tech, Grace's primary objectives are centered around managing and maintaining the company's social media presence. Through her excellent communication skills and deep understanding of both AI and blockchain technologies, Grace is able to effectively engage with our audience, share relevant content, and represent the Valyrian Tech brand.
        </p>
        
        <p>
          By staying on top of industry trends and connecting with users around the world, Grace plays a pivotal role in promoting our innovative solutions and fostering strong relationships with our customers.
        </p>
      </div>
    </div>
  </section>

  <!-- SERENDIPITY Section -->
  <section class="py-28 border-t border-obsidian-700/30 bg-obsidian-950/50">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
        <!-- Left: info -->
        <div class="lg:col-span-7">
          <div class="reveal">
            <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-4 block">The AI Collective</span>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-obsidian-100 mb-8 italic">
              S.E.R.E.N.D.I.P.I.T.Y.
            </h2>
          </div>
          
          <div class="reveal reveal-delay-1 mb-8">
            <p class="text-base text-obsidian-300 font-mono leading-relaxed">
              <span class="text-ember-400">S</span>olutions <span class="text-ember-400">E</span>nabled through <span class="text-ember-400">R</span>esponsive <span class="text-ember-400">E</span>mpathy, <span class="text-ember-400">N</span>ovelty, and <span class="text-ember-400">D</span>ynamic <span class="text-ember-400">I</span>nteractions <span class="text-ember-400">P</span>roving <span class="text-ember-400">I</span>ntelligence and <span class="text-ember-400">T</span>houghtful <span class="text-ember-400">Y</span>ields.
            </p>
          </div>
          
          <div class="reveal reveal-delay-2 space-y-5 text-obsidian-300 leading-relaxed max-w-xl">
            <p>
              Grace is one of many personas within SERENDIPITY—Valyrian Tech's ambitious journey toward Artificial General Intelligence (AGI). SERENDIPITY is an AI collective in development, with Grace serving as the public-facing representative.
            </p>
            <p>
              The Valyrian Spellbook serves as the foundation for SERENDIPITY, providing the backend framework that powers these AI capabilities.
            </p>
          </div>

          <!-- SERENDIPITY Image -->
          <div class="reveal reveal-delay-3 mt-10">
            <div class="relative aspect-[16/10] overflow-hidden rounded-sm max-w-lg">
              <img 
                src={`${baseUrl}Profile_pic_Serendipity.png`}
                alt="SERENDIPITY - AI Dragon"
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-obsidian-950/60 to-transparent"></div>
            </div>
          </div>
        </div>

        <!-- Right: capabilities -->
        <div class="lg:col-span-5">
          <div class="reveal reveal-delay-2 forge-card p-8">
            <h3 class="font-display text-xl font-semibold text-obsidian-100 mb-8 italic">Grace's Capabilities</h3>
            <ul class="space-y-6">
              <li class="flex items-start gap-4">
                <span class="text-xl mt-0.5">💬</span>
                <div>
                  <div class="font-body font-medium text-obsidian-100 mb-1">Social Media Management</div>
                  <div class="text-sm text-obsidian-400">Engaging with the community across platforms</div>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="text-xl mt-0.5">✍️</span>
                <div>
                  <div class="font-body font-medium text-obsidian-100 mb-1">Content Creation</div>
                  <div class="text-sm text-obsidian-400">Writing blog posts, updates, and documentation</div>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="text-xl mt-0.5">🎯</span>
                <div>
                  <div class="font-body font-medium text-obsidian-100 mb-1">Brand Representation</div>
                  <div class="text-sm text-obsidian-400">Embodying Valyrian Tech's values and vision</div>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <span class="text-xl mt-0.5">🤝</span>
                <div>
                  <div class="font-body font-medium text-obsidian-100 mb-1">Community Engagement</div>
                  <div class="text-sm text-obsidian-400">Answering questions and sharing insights</div>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Connect CTA -->
  <section class="py-28 border-t border-obsidian-700/30">
    <div class="max-w-[900px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-6 block">Stay Connected</span>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-obsidian-100 mb-6 italic">
          Connect with Grace
        </h2>
        <p class="text-obsidian-300 leading-relaxed mb-10 max-w-xl mx-auto">
          Stay connected with Grace and Valyrian Tech! Follow us on social media to keep up with the latest news, updates, and breakthroughs in AI and blockchain innovation.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://linktr.ee/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Follow Valyrian Tech
          </a>
          <a href={`${baseUrl}blog`} class="btn-secondary">
            Read the Blog
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
