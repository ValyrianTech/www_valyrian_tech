---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;

const projects = [
  {
    name: 'GenSelfie',
    description: 'GenSelfie is a cutting-edge platform that empowers creators to offer unique, AI-generated selfies to their audience. Using advanced generative models, GenSelfie transforms reference photos or creative prompts into stunning, personalized images—perfect for sharing, gifting, or building deeper connections with your community.',
    longDescription: 'Whether you\'re an online personality, artist, or content creator, GenSelfie makes it easy to expand your digital offerings. Delight your fans with custom selfies in a variety of styles and settings, all while maintaining full control over your creative process and privacy. With a user-friendly interface and secure data handling, GenSelfie is designed for creators who want to stand out and engage their audience in fresh, innovative ways.',
    icon: '📸',
    github: 'https://github.com/ValyrianTech/GenSelfie',
    website: 'https://genselfie.com',
    tags: ['AI', 'ComfyUI', 'FLUX', 'Influencers'],
    features: ['AI-powered image generation', 'Multiple style presets', 'Bitcoin Lightning payments', 'Social media integration', 'Privacy-first design'],
  },
  {
    name: 'Valyrian Spellbook',
    description: 'An Open Source framework that combines the power of Artificial Intelligence and Blockchain technology, allowing you to create the back end of your applications with ease.',
    longDescription: 'Whether you\'re an experienced developer or have no coding skills at all, Valyrian Spellbook lets you build your applications in a fraction of the time it would take to create them from scratch. Configure a REST API server with triggers and actions to automate your transactions. The Spellbook is the backbone of many Valyrian Tech projects—including SERENDIPITY, our own AI collective.',
    icon: '📖',
    github: 'https://github.com/ValyrianTech/ValyrianSpellbook',
    tags: ['Framework', 'REST API', 'Bitcoin', 'Python'],
    features: ['Configurable REST API', 'Trigger & action system', 'Bitcoin integration', 'Email handling', 'Authentication built-in'],
  },
  {
    name: 'Hivemind Protocol',
    description: 'A fairer way for teams, communities, or even friend groups to make decisions—without the chaos. Uses ranked choice voting with a Condorcet algorithm.',
    longDescription: 'Hivemind Protocol uses ranked choice voting, so you can list your favorites in order. The system then finds the option that best reflects the group\'s true preferences—no more "winner takes all" or wasted votes. Data lives on IPFS, votes are signed with Bitcoin keys, and every step is open and verifiable.',
    icon: '🐝',
    github: 'https://github.com/ValyrianTech/hivemind-python',
    tags: ['Voting', 'IPFS', 'Bitcoin', 'Decentralized'],
    features: ['Ranked choice voting', 'Condorcet algorithm', 'IPFS storage', 'Cryptographic proof', 'Tamper-evident'],
  },
  {
    name: 'IPFSDictChain',
    description: 'Python dictionaries that live on IPFS. Portable, tamper-proof, and globally accessible data storage.',
    longDescription: 'With IPFSDictChain, your Python dictionaries become portable, tamper-proof, and globally accessible—thanks to IPFS. Add .save() to push your data to IPFS instantly. Use .load(cid) to bring it back—anywhere, anytime. Every version is content-addressed, so nothing gets lost or overwritten.',
    icon: '🔗',
    github: 'https://github.com/ValyrianTech/ipfs_dict_chain',
    tags: ['IPFS', 'Python', 'Decentralized', 'Storage'],
    features: ['Dict-like interface', 'IPFS storage', 'Version history', 'Content addressing', 'Audit trails'],
  },
  {
    name: 'HexGlobe',
    description: 'The world reimagined in hexagons. A platform for geo-data apps, games, and visualizations powered by Uber\'s H3 library.',
    longDescription: 'HexGlobe brings natural elegance to digital maps, offering smoother navigation, better connectivity, and less distortion than traditional square grids. Each hexagon is a "tile" you can fill with content, data, or interactive features. Perfect for strategy games, data visualization, urban planning, or teaching geography.',
    icon: '🌍',
    github: 'https://github.com/ValyrianTech/HexGlobe',
    tags: ['Maps', 'H3', 'Visualization', 'Games'],
    features: ['Hexagonal grid system', 'Uber H3 powered', 'Zoom & pan', 'Mod system', 'Open for frontends'],
  },
  {
    name: 'Bitcoin Message Signer',
    description: 'Mobile app for cryptographic message signing. Prove it\'s really you with Bitcoin keys—no middlemen, no tracking.',
    longDescription: 'With Bitcoin Message Signer, you simply scan a QR code, pick which Bitcoin key you want to use, and the app signs your message with a unique cryptographic signature. Instantly, that signature is sent to any website or service you choose—no fuss, no middlemen, and absolutely no tracking.',
    icon: '🔐',
    github: 'https://github.com/ValyrianTech/BitcoinMessageSigner',
    tags: ['Mobile', 'Bitcoin', 'Security', 'Privacy'],
    features: ['QR code scanning', 'Multiple key support', 'Webhook integration', 'No tracking', 'Open source'],
  },
  {
    name: 'Valyrian Games Leaderboard',
    description: 'An automated LLM benchmark where AI models compete in coding challenges. TrueSkill rankings, transparent results, live updates.',
    longDescription: 'The digital arena where large language models go head-to-head, and only the best rise to the top! Each model faces the same challenges—like writing the shortest code, solving tricky puzzles, or answering tough questions. Their performances are scored, ranked, and displayed for all to see.',
    icon: '🏆',
    github: 'https://github.com/ValyrianTech/ValyrianGamesLeaderboard',
    website: 'https://valyriantech.github.io/ValyrianGamesLeaderboard/',
    tags: ['AI', 'Benchmarks', 'LLM', 'Competition'],
    features: ['TrueSkill rankings', 'Automated games', 'Interactive charts', 'GitHub Actions', 'Open data'],
  },
  {
    name: 'Runpod Templates',
    description: 'One-click deploy solutions for AI tools. Ready-to-go Docker containers for ComfyUI, Text-generation-webui, TTS servers, and more.',
    longDescription: 'Setting up advanced AI software can be tricky—installing dependencies, configuring servers, and troubleshooting errors. With Runpod templates, all that complexity disappears. Each template is a ready-to-go Docker container: just pick the tool you want, click "deploy," and you\'re up and running in minutes.',
    icon: '🚀',
    github: 'https://github.com/ValyrianTech/ComfyUI_with_Flux',
    website: 'https://console.runpod.io/deploy?template=rzg5z3pls5&ref=2vdt3dn9',
    tags: ['Docker', 'AI', 'ComfyUI', 'TTS'],
    features: ['One-click deploy', 'ComfyUI + FLUX', 'Text-generation-webui', 'F5-TTS server', 'ACE-Step music'],
  },
  {
    name: 'ACE-Step 1.5 XL',
    description: 'API server for ACE-Step 1.5 XL music generation. Deploy on RunPod with all models pre-loaded and ready to use immediately.',
    longDescription: 'ACE-Step 1.5 XL is a powerful music generation API server packaged as a Docker image with XL models baked in (~20GB). It features GPU support via NVIDIA CUDA 13 runtime and LLM-powered features for lyrics and caption formatting. Deploy instantly on RunPod or run locally with Docker Compose.',
    icon: '🎵',
    github: 'https://github.com/ValyrianTech/ace-step-1.5-xl',
    website: 'https://console.runpod.io/deploy?template=5fn9cdbhtr&ref=2vdt3dn9',
    tags: ['AI', 'Music', 'Docker', 'RunPod'],
    features: ['XL models pre-loaded', 'REST API server', 'GPU acceleration', 'LLM-powered lyrics', 'One-click RunPod deploy'],
  },
  {
    name: 'Qwen3-TTS Server',
    description: 'API server for Qwen3-TTS with voice cloning, voice conversion, and multi-language support for 10 languages.',
    longDescription: 'Qwen3-TTS Server provides high-quality text-to-speech synthesis with advanced features like voice cloning from short reference audio clips and voice conversion for existing audio files. Supports Chinese, English, Japanese, Korean, German, French, Russian, Portuguese, Spanish, and Italian. Uses Whisper for automatic transcription and includes speed control via time-stretching.',
    icon: '🗣️',
    github: 'https://github.com/ValyrianTech/Qwen3-TTS_server',
    website: 'https://console.runpod.io/deploy?template=h8fjq3psk4&ref=2vdt3dn9',
    tags: ['TTS', 'AI', 'Voice Cloning', 'Docker'],
    features: ['Voice cloning', 'Voice conversion', '10 language support', 'Whisper transcription', 'Speed control'],
  },
  {
    name: 'VibeVoice Server',
    description: 'High-quality text-to-speech API server with voice cloning, multiple voice presets, and RTX 5090 Blackwell GPU support.',
    longDescription: 'VibeVoice Server delivers high-quality text-to-speech synthesis with voice cloning capabilities from reference audio. Features multiple voice presets, voice conversion for existing audio files, and Docker support with RunPod compatibility. Optimized for the latest NVIDIA hardware including RTX 5090 Blackwell GPUs.',
    icon: '🎤',
    github: 'https://github.com/ValyrianTech/VibeVoice_server',
    website: 'https://console.runpod.io/deploy?template=xb51emh3pj&ref=2vdt3dn9',
    tags: ['TTS', 'AI', 'Voice Cloning', 'Docker'],
    features: ['High-quality TTS', 'Voice cloning', 'Multiple presets', 'Voice conversion', 'RTX 5090 support'],
  },
];
---

<BaseLayout title="Projects" description="Explore Valyrian Tech's open source projects - AI tools, blockchain solutions, and developer frameworks.">
  <!-- Hero -->
  <section class="pt-12 pb-20">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal max-w-3xl">
        <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-6 block">Open Source</span>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-obsidian-100 italic leading-tight mb-6">
          Projects <span class="text-gradient">Forged</span> in Code
        </h1>
        <p class="text-lg text-obsidian-300 max-w-xl">
          All tools are free and open source. Explore, contribute, fork, and build something amazing.
        </p>
      </div>
    </div>
  </section>

  <!-- Projects List -->
  <section class="pb-28 border-t border-obsidian-700/30 pt-28">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="space-y-0 divide-y divide-obsidian-700/30">
        {projects.map((project, index) => (
          <div class={`reveal reveal-delay-${(index % 3) + 1} py-12 first:pt-0 last:pb-0`}>
            <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
              <!-- Main Info -->
              <div class="lg:col-span-7">
                <div class="flex items-start gap-4 mb-4">
                  <span class="text-3xl">{project.icon}</span>
                  <div>
                    <h2 class="font-display text-2xl md:text-3xl font-bold text-obsidian-100 italic">{project.name}</h2>
                    <div class="flex flex-wrap gap-2 mt-3">
                      {project.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <p class="text-obsidian-200 mb-3 leading-relaxed">{project.description}</p>
                <p class="text-obsidian-300 text-sm leading-relaxed">{project.longDescription}</p>
                
                <!-- Links -->
                <div class="flex flex-wrap gap-3 mt-6">
                  <a href={project.github} target="_blank" rel="noopener noreferrer" class="btn-secondary text-xs py-2.5">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    GitHub
                  </a>
                  {project.website && (
                    <a href={project.website} target="_blank" rel="noopener noreferrer" class="btn-primary text-xs py-2.5">
                      Visit Site
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>

              <!-- Features -->
              <div class="lg:col-span-5 lg:border-l lg:border-obsidian-700/30 lg:pl-10">
                <h3 class="font-mono text-xs tracking-widest-plus uppercase text-obsidian-500 mb-5">Key Features</h3>
                <ul class="space-y-3">
                  {project.features.map((feature) => (
                    <li class="flex items-center gap-2.5 text-sm text-obsidian-300">
                      <svg class="w-3.5 h-3.5 text-ember-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Projects -->
  <section class="py-28 border-t border-obsidian-700/30 bg-obsidian-950/50">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-8 lg:px-12">
      <div class="reveal mb-16">
        <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-3 block">Infrastructure</span>
        <h2 class="section-heading text-obsidian-100">
          More Docker Templates & <span class="text-gradient">Tools</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-px bg-obsidian-700/20">
        <div class="reveal reveal-delay-1 p-6 bg-obsidian-950/80 group transition-colors duration-500 hover:bg-obsidian-800/50">
          <div class="text-2xl mb-3">🎨</div>
          <a href="https://github.com/ValyrianTech/ComfyUI_with_Flux" target="_blank" rel="noopener noreferrer" class="font-display text-base font-semibold text-obsidian-100 italic hover:text-ember-400 transition-colors block">ComfyUI + FLUX</a>
          <div class="text-xs text-obsidian-500 font-mono tracking-wider mt-1 mb-4">Image Generation</div>
          <a href="https://console.runpod.io/deploy?template=rzg5z3pls5&ref=2vdt3dn9" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-mono tracking-wider uppercase px-3 py-1.5 bg-ember-600 hover:bg-ember-500 text-white rounded-sm transition-colors">Deploy</a>
        </div>
        <div class="reveal reveal-delay-2 p-6 bg-obsidian-950/80 group transition-colors duration-500 hover:bg-obsidian-800/50">
          <div class="text-2xl mb-3">💬</div>
          <a href="https://github.com/ValyrianTech/text-generation-webui_docker" target="_blank" rel="noopener noreferrer" class="font-display text-base font-semibold text-obsidian-100 italic hover:text-ember-400 transition-colors block">Text-gen-webui</a>
          <div class="text-xs text-obsidian-500 font-mono tracking-wider mt-1 mb-4">LLM Interface</div>
          <a href="https://console.runpod.io/deploy?template=bzhe0deyqj&ref=2vdt3dn9" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-mono tracking-wider uppercase px-3 py-1.5 bg-ember-600 hover:bg-ember-500 text-white rounded-sm transition-colors">Deploy</a>
        </div>
        <div class="reveal reveal-delay-3 p-6 bg-obsidian-950/80 group transition-colors duration-500 hover:bg-obsidian-800/50">
          <div class="text-2xl mb-3">🎙️</div>
          <a href="https://github.com/ValyrianTech/F5-TTS_server" target="_blank" rel="noopener noreferrer" class="font-display text-base font-semibold text-obsidian-100 italic hover:text-ember-400 transition-colors block">F5-TTS Server</a>
          <div class="text-xs text-obsidian-500 font-mono tracking-wider mt-1 mb-4">Text to Speech</div>
          <a href="https://console.runpod.io/deploy?template=x9wtzn9izl&ref=2vdt3dn9" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-mono tracking-wider uppercase px-3 py-1.5 bg-ember-600 hover:bg-ember-500 text-white rounded-sm transition-colors">Deploy</a>
        </div>
        <div class="reveal reveal-delay-4 p-6 bg-obsidian-950/80 group transition-colors duration-500 hover:bg-obsidian-800/50">
          <div class="text-2xl mb-3">🔊</div>
          <a href="https://github.com/ValyrianTech/OpenVoice_server" target="_blank" rel="noopener noreferrer" class="font-display text-base font-semibold text-obsidian-100 italic hover:text-ember-400 transition-colors block">OpenVoice Server</a>
          <div class="text-xs text-obsidian-500 font-mono tracking-wider mt-1 mb-4">Voice Cloning</div>
          <a href="https://console.runpod.io/deploy?template=qo8v6w92q2&ref=2vdt3dn9" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-mono tracking-wider uppercase px-3 py-1.5 bg-ember-600 hover:bg-ember-500 text-white rounded-sm transition-colors">Deploy</a>
        </div>
        <div class="reveal reveal-delay-5 p-6 bg-obsidian-950/80 group transition-colors duration-500 hover:bg-obsidian-800/50">
          <div class="text-2xl mb-3">🎵</div>
          <a href="https://github.com/ValyrianTech/ace-step-1.5" target="_blank" rel="noopener noreferrer" class="font-display text-base font-semibold text-obsidian-100 italic hover:text-ember-400 transition-colors block">ACE-Step 1.5</a>
          <div class="text-xs text-obsidian-500 font-mono tracking-wider mt-1 mb-4">Music Generation</div>
          <a href="https://console.runpod.io/deploy?template=uuc79b5j3c&ref=2vdt3dn9" target="_blank" rel="noopener noreferrer" class="inline-block text-xs font-mono tracking-wider uppercase px-3 py-1.5 bg-ember-600 hover:bg-ember-500 text-white rounded-sm transition-colors">Deploy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 border-t border-obsidian-700/30">
    <div class="max-w-[900px] mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <div class="reveal">
        <span class="font-mono text-xs tracking-widest-plus uppercase text-ember-400 mb-6 block">Contribute</span>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-obsidian-100 mb-6 italic">
          Want to Contribute?
        </h2>
        <p class="text-obsidian-300 leading-relaxed mb-10 max-w-xl mx-auto">
          All projects welcome contributions. Check out the repositories, open issues, submit PRs, or just star your favorites!
        </p>
        <a href="https://github.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Visit ValyrianTech on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
