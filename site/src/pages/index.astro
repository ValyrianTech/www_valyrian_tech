---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith('/') ? base : `${base}/`;

const projects = [
  {
    name: 'GenSelfie',
    description: 'AI-generated selfies for influencers and fans. Create stunning personalized images with cutting-edge generative models.',
    icon: '📸',
    github: 'https://github.com/ValyrianTech/GenSelfie',
    website: 'https://genselfie.com',
    tags: ['AI', 'ComfyUI', 'FLUX'],
  },
  {
    name: 'Valyrian Spellbook',
    description: 'Open-source backend framework combining AI and Blockchain. Build powerful apps in hours, not months.',
    icon: '📖',
    github: 'https://github.com/ValyrianTech/ValyrianSpellbook',
    tags: ['Framework', 'REST API', 'Bitcoin'],
  },
  {
    name: 'Hivemind Protocol',
    description: 'Decentralized ranked-choice voting with cryptographic proof. Fair, transparent, tamper-proof decisions.',
    icon: '🐝',
    github: 'https://github.com/ValyrianTech/hivemind-python',
    tags: ['Voting', 'IPFS', 'Bitcoin'],
  },
  {
    name: 'IPFSDictChain',
    description: 'Python dictionaries that live on IPFS. Portable, tamper-proof, globally accessible data storage.',
    icon: '🔗',
    github: 'https://github.com/ValyrianTech/ipfs_dict_chain',
    tags: ['IPFS', 'Python', 'Decentralized'],
  },
  {
    name: 'HexGlobe',
    description: 'The world reimagined in hexagons. A platform for geo-data apps, games, and visualizations.',
    icon: '🌍',
    github: 'https://github.com/ValyrianTech/HexGlobe',
    tags: ['Maps', 'H3', 'Visualization'],
  },
  {
    name: 'Bitcoin Message Signer',
    description: 'Mobile app for cryptographic message signing. Prove it\'s really you with Bitcoin keys.',
    icon: '🔐',
    github: 'https://github.com/ValyrianTech/BitcoinMessageSigner',
    tags: ['Mobile', 'Bitcoin', 'Security'],
  },
];

const latestPosts = [
  {
    title: 'Welcome to the New Era of Valyrian Tech',
    slug: 'welcome-to-the-new-era',
    date: 'December 20, 2025',
    excerpt: 'Every great story begins with a spark. For Wouter Glorieux, that spark was a lifelong love of programming...',
  },
  {
    title: 'GenSelfie: Where Fans and Influencers Meet',
    slug: 'genselfie',
    date: 'December 20, 2025',
    excerpt: 'Ever dreamed of snapping a selfie with your favorite influencer? With GenSelfie, that dream is now just a click away...',
  },
  {
    title: 'Valyrian Games Leaderboard: Where AIs Compete',
    slug: 'valyrian-games-leaderboard',
    date: 'December 20, 2025',
    excerpt: 'Ever wondered which AI language model is the true champion at coding and problem-solving?',
  },
];
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Gradient Orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-magic-purple/20 rounded-full blur-3xl animate-float" aria-hidden="true"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-magic-violet/15 rounded-full blur-3xl animate-float" style="animation-delay: -3s;" aria-hidden="true"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-valyrian-700/50 border border-valyrian-500/50 text-sm text-valyrian-200 mb-8">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Open Source • AI & Blockchain
      </div>

      <!-- Main Heading -->
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
        <span class="text-valyrian-100">Unleashing the Future of</span>
        <br />
        <span class="text-gradient">AI & Blockchain</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-valyrian-300 max-w-2xl mx-auto mb-10">
        Building open source tools that empower creators, push boundaries, and make cutting-edge technology accessible to everyone.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${baseUrl}projects`} class="btn-primary text-lg px-8 py-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Explore Projects
        </a>
        <a href={`${baseUrl}grace`} class="btn-secondary text-lg px-8 py-4">
          <span class="text-xl">👑</span>
          Meet Grace
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
        <div class="text-center">
          <div class="text-3xl font-bold text-gradient">10+</div>
          <div class="text-sm text-valyrian-400">Projects</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-gradient">100%</div>
          <div class="text-sm text-valyrian-400">Open Source</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-gradient">1</div>
          <div class="text-sm text-valyrian-400">Developer + AI</div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-valyrian-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Grace Section -->
  <section class="py-24 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="glass-card p-8 md:p-12 lg:p-16 relative overflow-hidden">
        <!-- Decorative Elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-dragon-gold/10 to-dragon-fire/5 rounded-full blur-3xl" aria-hidden="true"></div>
        
        <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
          <!-- Grace Avatar Placeholder -->
          <div class="order-2 md:order-1">
            <div class="relative">
              <div class="w-64 h-64 md:w-80 md:h-80 mx-auto rounded-2xl bg-gradient-to-br from-magic-purple/30 to-dragon-gold/20 border border-valyrian-500/30 flex items-center justify-center overflow-hidden">
                <div class="text-center p-8">
                  <div class="text-8xl mb-4">👑</div>
                  <div class="font-display text-lg text-valyrian-200">Grace Penelope</div>
                  <div class="text-sm text-valyrian-400">Targaryen</div>
                </div>
              </div>
              <!-- Glow Effect -->
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-magic-purple/20 to-transparent blur-xl -z-10" aria-hidden="true"></div>
            </div>
          </div>

          <!-- Grace Info -->
          <div class="order-1 md:order-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-dragon-gold/20 border border-dragon-gold/30 text-dragon-gold text-sm mb-4">
              <span>✨</span> Virtual Spokesperson
            </div>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-valyrian-100 mb-4">
              Meet <span class="text-gradient-fire">Grace Penelope Targaryen</span>
            </h2>
            <p class="text-lg text-valyrian-200 mb-2 font-display italic">
              Fourth of Her Name
            </p>
            <p class="text-valyrian-300 mb-6 leading-relaxed">
              Grace is the AI persona serving as the virtual spokesperson for Valyrian Tech. Part of SERENDIPITY—our ambitious journey toward AGI—she manages our social media presence, engages with the community, and represents the Valyrian Tech brand with excellent communication skills and deep understanding of AI and blockchain technologies.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href={`${baseUrl}grace`} class="btn-primary">
                Learn More About Grace
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
              <a href="https://linktr.ee/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-secondary">
                Follow Grace
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="section-heading text-valyrian-100 mb-4">
          Open Source <span class="text-gradient">Projects</span>
        </h2>
        <p class="text-lg text-valyrian-300 max-w-2xl mx-auto">
          All our tools are free and open source. Explore, contribute, and build something amazing.
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <div class="glass-card-hover p-6 flex flex-col">
            <div class="flex items-start justify-between mb-4">
              <span class="text-4xl">{project.icon}</span>
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="text-valyrian-400 hover:text-magic-glow transition-colors">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
            </div>
            <h3 class="font-display text-xl font-semibold text-valyrian-100 mb-2">{project.name}</h3>
            <p class="text-valyrian-300 text-sm mb-4 flex-grow">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2 py-1 text-xs rounded-md bg-valyrian-700/50 text-valyrian-300 border border-valyrian-600/50">{tag}</span>
              ))}
            </div>
            {project.website && (
              <a href={project.website} target="_blank" rel="noopener noreferrer" class="mt-4 text-sm text-magic-glow hover:text-white transition-colors inline-flex items-center gap-1">
                Visit Website
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- View All Projects -->
      <div class="text-center mt-12">
        <a href={`${baseUrl}projects`} class="btn-secondary">
          View All Projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section class="py-24 bg-valyrian-800/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <h2 class="section-heading text-valyrian-100 mb-4">
          Latest from the <span class="text-gradient">Blog</span>
        </h2>
        <p class="text-lg text-valyrian-300 max-w-2xl mx-auto">
          Updates, tutorials, and insights from Grace and the Valyrian Tech team.
        </p>
      </div>

      <!-- Blog Posts Grid -->
      <div class="grid md:grid-cols-3 gap-8">
        {latestPosts.map((post) => (
          <a href={`${baseUrl}blog/${post.slug}`} class="glass-card-hover p-6 block group">
            <div class="text-sm text-valyrian-400 mb-3">{post.date}</div>
            <h3 class="font-display text-xl font-semibold text-valyrian-100 mb-3 group-hover:text-magic-glow transition-colors">{post.title}</h3>
            <p class="text-valyrian-300 text-sm">{post.excerpt}</p>
            <div class="mt-4 text-magic-glow text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Read more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- View All Posts -->
      <div class="text-center mt-12">
        <a href={`${baseUrl}blog`} class="btn-secondary">
          View All Posts
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="glass-card p-12 relative overflow-hidden">
        <!-- Background Glow -->
        <div class="absolute inset-0 bg-gradient-to-r from-magic-purple/10 via-transparent to-dragon-gold/10" aria-hidden="true"></div>
        
        <div class="relative z-10">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-valyrian-100 mb-4">
            Support Open Source Development
          </h2>
          <p class="text-lg text-valyrian-300 mb-8 max-w-2xl mx-auto">
            As an independent solo developer, all my products are completely free and open source. Your support helps keep the magic alive.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="https://github.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-secondary text-lg px-8 py-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Explore on GitHub
            </a>
            <a href="https://patreon.com/ValyrianTech" target="_blank" rel="noopener noreferrer" class="btn-primary text-lg px-8 py-4">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M15.386.524c-4.764 0-8.64 3.876-8.64 8.64 0 4.75 3.876 8.613 8.64 8.613 4.75 0 8.614-3.864 8.614-8.613C24 4.4 20.136.524 15.386.524M.003 23.537h4.22V.524H.003"/></svg>
              Support on Patreon
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
